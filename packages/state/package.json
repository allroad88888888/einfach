{
  "name": "einfach-state",
  "version": "0.11.11",
  "description": "react易上手状态管理",
  "type": "module",
  "main": "./cjs/index.js",
  "exports": {
    ".": {
      "import": "./esm/index.mjs",
      "require": "./cjs/index.js"
    },
    "./*": {
      "import": "./esm/*.mjs",
      "require": "./cjs/*.js"
    }
  },
  "typings": "@types/index.d.ts",
  "license": "MIT",
  "files": [
    "esm",
    "cjs",
    "@types",
    "README.md"
  ],
  "scripts": {
    "build": "tsc"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=14.18.0"
  },
  "keywords": [
    "react",
    "atom"
  ],
  "peerDependencies": {
    "react": ">=16.8 <20"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3"
  },
  "dependencies": {}
}